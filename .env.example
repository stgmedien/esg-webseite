# ── Neon Postgres ──────────────────────────────────────────────
# Connection-String aus dem Neon-Dashboard (mit ?sslmode=require).
DATABASE_URL="postgresql://user:pass@ep-xxx.eu-central-1.aws.neon.tech/neondb?sslmode=require"

# ── Brevo ──────────────────────────────────────────────────────
# API-Key v3 aus Brevo → "SMTP & API" → "API Keys".
BREVO_API_KEY="xkeysib-..."
# ID der Kontaktliste (per `npm run brevo:setup` anlegbar/auslesbar).
BREVO_LIST_ID="0"
# ID des Double-Opt-In-Mailtemplates (Brevo → Kampagnen → Vorlagen).
BREVO_DOI_TEMPLATE_ID="0"
# Optionales Shared Secret zum Absichern des Brevo-Webhooks (?token=...).
BREVO_WEBHOOK_SECRET=""

# ── Site ───────────────────────────────────────────────────────
# Öffentliche Basis-URL (für DOI-Redirect & Metadaten).
# Lokal: http://localhost:3000 · Prod: https://<deine-vercel-domain>
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
